<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>

<Pane xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.sae2.controller.ShopController"
      mouseTransparent="false">

    <VBox fx:id="interfaceBoutique" visible="false" alignment="CENTER" spacing="15"
          prefWidth="260" prefHeight="180"
          style="-fx-background-color: rgba(0, 0, 0, 0.85); -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: gold; -fx-border-width: 2; -fx-border-radius: 10;">
        <Label text="BOUTIQUE" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Label fx:id="labelPrixBooster" style="-fx-text-fill: gold; -fx-font-size: 13px;"/>
        <Button text="Acheter Booster" onAction="#traiterAchatBooster" style="-fx-font-size: 13px; -fx-padding: 6 12;"/>
        <Button text="Fermer" onAction="#fermerBoutique" style="-fx-font-size: 11px; -fx-padding: 4 10;"/>
    </VBox>

    <VBox fx:id="interfaceChoixBooster" visible="false" alignment="CENTER" spacing="20"
          prefWidth="320" prefHeight="220"
          style="-fx-background-color: rgba(0, 0, 0, 0.9); -fx-background-radius: 10; -fx-padding: 20; -fx-border-color: #8A2BE2; -fx-border-width: 2; -fx-border-radius: 10;">
        <Label text="CHOISISSEZ UNE CARTE" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
        <HBox spacing="30" alignment="CENTER">
            <ImageView fx:id="choix1View" fitWidth="80" fitHeight="115" style="-fx-cursor: hand;" onMouseClicked="#clicChoix1"/>
            <ImageView fx:id="choix2View" fitWidth="80" fitHeight="115" style="-fx-cursor: hand;" onMouseClicked="#clicChoix2"/>
        </HBox>
    </VBox>
</Pane>